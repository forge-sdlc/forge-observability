# forge-observability — environment variables
# Copy this file to .env and fill in your values.

# ── Grafana ───────────────────────────────────────────────────────
GRAFANA_PORT=3010
# Path to the built grafana-langfuse-datasource plugin dist/ directory.
# Default assumes grafana-langfuse-datasource is cloned next to this repo
# TODO communicate with langfuse through host.containers.internal (grafana langfuse plugin)
# LANGFUSE_PLUGIN_DIST=/absolute/path/to/grafana-langfuse-datasource/dist

# ── Langfuse ClickHouse ───────────────────────────────────────────
# Used by Grafana (containerized) to reach the host
CLICKHOUSE_HOST=host.containers.internal
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=clickhouse

# ── Langfuse API (for devtools/langfuse/seed.py) ─────────────────
# Copy these from your Langfuse project settings
LANGFUSE_HOST=localhost
LANGFUSE_PORT=3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Forge Prometheus (already running as part of Forge) ──────────
PROMETHEUS_HOST=host.containers.internal
PROMETHEUS_PORT=9092

# ── Forge Redis (already running as part of Forge) ───────────────
# Used by Grafana (containerized) to reach the host
REDIS_HOST=host.containers.internal
REDIS_PORT=6380
