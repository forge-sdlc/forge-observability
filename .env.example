# forge-observability — environment variables
# Copy this file to .env and fill in your values.

# ── ClickHouse analytical store ───────────────────────────────────────────
# use localhost for running services locally or
#     host.containers.internal for running services in containers
CLICKHOUSE_HOST=host.containers.internal
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USER=forge
CLICKHOUSE_PASSWORD=forge

# ── Forge Observability Worker ──────────────────────────────────
FORGE_OBSERVABILITY_WORKER_LOG_LEVEL=INFO
FORGE_OBSERVABILITY_WORKER_SKIP_DBT=false

# Pipeline polling intervals
LANGFUSE_INTERVAL_SECONDS=60

# ── Langfuse (LLM observability) ─────────────────────────────────────────
# use localhost for running services locally or
#     host.containers.internal for running services in containers
LANGFUSE_HOST=host.containers.internal
LANGFUSE_PORT=3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Grafana (compose.grafana.yml) ────────────────────────────────────────
# Path to the built grafana-langfuse-datasource plugin dist/ directory.
# Default assumes grafana-langfuse-datasource is cloned next to this repo.
LANGFUSE_PLUGIN_DIST=/absolute/path/to/grafana-langfuse-datasource/dist
