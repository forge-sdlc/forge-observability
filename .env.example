# forge-observability — environment variables
# Copy this file to .env and fill in your values.

# ── ClickHouse analytical store ───────────────────────────────────────────
# Container development: use host.containers.internal 
#     to cross network boundaries.
CLICKHOUSE_HOST=host.containers.internal
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USER=forge
CLICKHOUSE_PASSWORD=forge

# ── Forge Observability API ──────────────────────────────────────────────
FORGE_OBSERVABILITY_API_PORT=8010
FORGE_OBSERVABILITY_API_LOG_LEVEL=INFO

# ── Forge Observability Worker ──────────────────────────────────
FORGE_OBSERVABILITY_WORKER_LOG_LEVEL=INFO
# Pipeline polling intervals
LANGFUSE_INTERVAL_SECONDS=60
PROMETHEUS_INTERVAL_SECONDS=300
GITHUB_INTERVAL_SECONDS=600
JIRA_INTERVAL_SECONDS=600      

# ── Langfuse (LLM observability) ─────────────────────────────────────────
# Container development: use host.containers.internal 
#     to cross network boundaries.
LANGFUSE_HOST=host.containers.internal
LANGFUSE_PORT=3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Prometheus (app metrics) ──────────────────────────────────────────────
# Container development: use host.containers.internal
#     to cross network boundaries.
PROMETHEUS_HOST=host.containers.internal
PROMETHEUS_PORT=9092

# ── GitHub ────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
# Comma-separated list of repos to ingest: owner/repo,owner/other
GITHUB_KNOWN_REPOS=

# ── JIRA ──────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER_EMAIL=
JIRA_API_TOKEN=
