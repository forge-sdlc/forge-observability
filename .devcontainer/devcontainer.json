{
  "name": "forge-observability",
  "image": "mcr.microsoft.com/devcontainers/python:3",
  "remoteUser": "root",
  // Start datastore on the host before the devcontainer launches so the
  // e.g., ClickHouse
  "initializeCommand": "podman compose --env-file .env -f devtools/compose.clickhouse.yml up -d",
  // Install uv and sync dependencies once after container creation.
  "onCreateCommand": "pipx install uv && uv sync",
  // Join the same Docker network as ClickHouse so we can reach it by
  // its service name ("clickhouse") rather than localhost.
  "runArgs": [
    "--env-file",
    "${localWorkspaceFolder}/.env"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python"
      }
    }
  }
}
