      "panel-11": {
        "kind": "Panel",
        "spec": {
          "id": 11,
          "title": "Total Cost Over Time",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-clickhouse-datasource",
                      "version": "v0",
                      "datasource": {
                        "name": "langfuse-clickhouse"
                      },
                      "spec": {
                        "format": "table",
                        "rawSql": "SELECT $__timeInterval(t.timestamp) as time, sum(o.total_cost) as total_cost FROM default.traces t FINAL JOIN default.observations o FINAL ON t.id = o.trace_id WHERE $__timeFilter(t.timestamp) AND t.session_id IN ($jira_issue) AND hasAny(t.tags, [$ticket_type]) GROUP BY time ORDER BY time"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
